{
  "name": "kratos-memory",
  "version": "1.3.4",
  "description": "Persistent memory for AI coding agents — CLI-first, encrypted, local",
  "main": "dist/cli/index.js",
  "type": "module",
  "bin": {
    "kratos-memory": "./bin/kratos-cli",
    "kratos": "./bin/kratos-cli"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ceorkm/kratos-cli.git"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "npm run build && node --test tests/*.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "ai-memory",
    "ai-agents",
    "claude-code",
    "codex",
    "cursor",
    "sqlite",
    "fts5",
    "memory",
    "persistent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*",
    "bin/**/*",
    "README.md",
    "LICENSE",
    "AGENTS.md"
  ]
}
